{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildEnvironment": "V3"
  },
  "deploy": {
    "runtime": "V2",
    "numReplicas": 1,
    "startCommand": "uvicorn fastapi_app:app --host 0.0.0.0 --port $PORT",
    "sleepApplication": false,
    "useLegacyStacker": false,
    "ipv6EgressEnabled": false
  }
}
